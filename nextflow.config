// nextflow.config — RNA-seq annotation pipeline
// Tools come from conda envs on the compute host; adjust ANNOT_BIN if needed.

params {
  genome   = null
  reads    = null
  proteome = null
  pfam     = null
  outdir   = 'annot_out'
}

// Make the annotation toolchain (HISAT2, StringTie, TransDecoder, samtools, diamond, hmmer)
// visible to every process. Point these at your conda envs.
env {
  ANNOT_BIN = '/home/k821209/miniconda3/envs/annot/bin'
  NF_BIN    = '/home/k821209/miniconda3/envs/nf/bin'   // diamond, (hmmer if installed here)
  PATH      = '/home/k821209/miniconda3/envs/annot/bin:/home/k821209/miniconda3/envs/nf/bin:' + System.getenv('PATH')
  CONDA_PREFIX = '/home/k821209/miniconda3/envs/annot'
}

process {
  executor = 'local'
  cpus = 8
  withName: HISAT2_BUILD   { cpus = 24 }
  withName: HISAT2_ALIGN   { cpus = 36 }
  withName: STRINGTIE_MERGE{ cpus = 24 }
  withName: DIAMOND        { cpus = 36 }
  withName: PFAM           { cpus = 24 }
  withName: PREDICT        { cpus = 16 }
}

executor { cpus = 40 }   // node3: 40 cores

profiles {
  // example invocation values for this project
  hobak {
    params.genome   = "${launchDir}/ragtag_out/ragtag.scaffold.fasta"
    params.reads    = "${launchDir}/rnaseq/*_{1,2}.fastq.gz"
    params.proteome = "${launchDir}/db/uniprot-all.fasta"
    // params.pfam  = "${launchDir}/db/Pfam-A.hmm"   // optional (slow)
    params.outdir   = "${launchDir}/annot_nf"
  }
}
