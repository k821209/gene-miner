// nextflow.v2.config — working Gene-Miner pipeline for finished (chromosome-scale) genomes.
// Tools are supplied per-process via conda env PREFIX paths (envs already exist on host).
params {
  genome           = null          // genome FASTA (required)
  reads            = null          // RNA-seq glob, e.g. "rnaseq/*_{1,2}.fastq.gz" (required)
  proteome         = null          // protein FASTA for DIAMOND (required)
  pfam             = null          // optional Pfam-A.hmm
  augustus_species = null          // native AUGUSTUS model name; null => BUSCO-train one
  repeat_lib       = null          // optional RepeatModeler lib; null => de novo
  run_genemark     = false         // add GeneMark-ETP as a 3rd ab-initio stream
  genemark_gtf     = null          // precomputed GeneMark-ETP genemark.gtf; null + run_genemark => run it in-pipeline
  busco_lineage    = "embryophyta_odb10"
  gene_prefix      = "GMG"
  aug_score        = 0.8
  aug_min_aa       = 100
  te_thresh        = 0.5
  window_mb        = 5             // AUGUSTUS window size (Mb)
  window_overlap   = 100000        // window overlap (bp)
  run_qc           = true
  outdir           = "gm_out"
  // conda env prefixes (host)
  env_annot    = "/home/k821209/miniconda3/envs/annot"
  env_augustus = "/home/k821209/miniconda3/envs/augustus"
  env_rmod     = "/home/k821209/miniconda3/envs/rmod"
  env_eggnog   = "/home/k821209/miniconda3/envs/eggnog"
  env_busco    = "/home/k821209/miniconda3/envs/busco"
  eggnog_db    = "/home/k821209/eggnog_db"
}
conda.enabled = true
process {
  executor = "local"
  cpus = 8
  withName: MASK_GENOME    { cpus = 12 }   // RepeatModeler; runs concurrently with BUSCO_TRAIN
  withName: BUSCO_TRAIN    { cpus = 10 }   // BUSCO --long; concurrent with masking (12+10=22)
  withName: HISAT2_BUILD   { cpus = 12 }
  withName: HISAT2_ALIGN   { cpus = 10 }
  withName: STRINGTIE      { cpus = 8  }
  withName: STRINGTIE_MERGE{ cpus = 8  }
  withName: TRANSDECODER    { cpus = 16 }
  withName: AUGUSTUS_PREDICT{ cpus = 20 }
  withName: GENEMARK_ETP   { cpus = 22 }
  withName: EGGNOG         { cpus = 16 }
  withName: BUSCO          { cpus = 16 }
}
executor { cpus = 22 }   // deevo-219: 24 cores, leave 2 free
